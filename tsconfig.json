  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "esnext",
